rules_version = '2';

// All reads and writes go through the Firebase Admin SDK (server-side), which
// bypasses these rules. The client SDK is used for Auth only. So deny every
// direct client request to Firestore.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
